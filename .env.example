# Supabase (dejar vacío para usar datos mock en memoria)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# true = mock en memoria | false + URL Supabase = persistencia real
NEXT_PUBLIC_USE_MOCK_DATA=true

# Firma de la cookie de sesión (obligatorio en local; usar valor aleatorio largo)
SESSION_SECRET=cambiar-por-un-secreto-aleatorio-largo
