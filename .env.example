# Firebase Auth
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Supabase — Project URL (Settings → API). Solo el dominio, SIN /rest/v1
NEXT_PUBLIC_APP_MODE=MOCK
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_USE_MOCK_DATA=true

# Para activar Supabase:
# NEXT_PUBLIC_APP_MODE=SUPABASE
# NEXT_PUBLIC_USE_MOCK_DATA=false
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon-public-key
# NO usar: https://xxxx.supabase.co/rest/v1  (el SDK lo agrega solo)

# Session
SESSION_SECRET=dev-session-secret-cambiar-en-produccion
